# =============================================
# AI健康饮食规划助手 - 服务器环境变量配置
# =============================================
# 使用方法：
#   1. 在服务器 /www/wwwroot/nutriai/ 目录下创建 .env 文件
#   2. cp .env.example .env && chmod 600 .env
#   3. 填入实际值
#
# 注意：此文件包含敏感信息，禁止提交到 Git 仓库
# =============================================

# ---------- Docker 镜像标签 ----------
# 由 GitHub Actions 部署时自动更新，无需手动修改
IMAGE_TAG=latest

# ---------- 云数据库 (腾讯云 MySQL) ----------
DB_HOST=bj-cynosdbmysql-grp-xxxxxxxx.sql.tencentcdb.com
DB_PORT=23593
DB_NAME=nutriai
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ---------- Redis ----------
REDIS_PASSWORD=your_redis_password

# ---------- JWT 认证 ----------
# 至少64字符的随机字符串，用于签发JWT Token
# 生成方法: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_at_least_64_characters_long_for_hs512

# ---------- 通义千问 AI ----------
TONGYI_API_KEY=sk-your_tongyi_api_key

# ---------- 腾讯云 COS 对象存储（可选）----------
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-beijing
COS_BUCKET=nutriai-xxxxxxxx

# ---------- 百度 AI（可选）----------
BAIDU_AI_APP_ID=
BAIDU_AI_API_KEY=
BAIDU_AI_SECRET_KEY=
