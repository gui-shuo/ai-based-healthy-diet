# =============================================
# AI健康饮食规划助手 - 环境变量配置
# =============================================
# 使用方法：
#   1. cp .env.example .env && chmod 600 .env
#   2. 填入实际的云资源值
#   3. 本地开发启动: ./start-dev.sh （自动加载 .env）
#      或手动: source .env && cd backend && mvn spring-boot:run
#
# 注意：.env 包含敏感信息，已被 .gitignore 排除
# =============================================

# ---------- Docker 镜像标签 ----------
# 由 GitHub Actions 部署时自动更新，无需手动修改
IMAGE_TAG=latest

# ---------- 云数据库 (腾讯云 MySQL) ----------
DB_HOST=bj-cynosdbmysql-grp-xxxxxxxx.sql.tencentcdb.com
DB_PORT=23593
DB_NAME=nutriai
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ---------- Redis ----------
REDIS_HOST=your-cloud-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ---------- JWT 认证 ----------
# 至少64字符的随机字符串，用于签发JWT Token
# 生成方法: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_at_least_64_characters_long_for_hs512

# ---------- 通义千问 AI ----------
TONGYI_API_KEY=sk-your_tongyi_api_key

# ---------- 腾讯云 COS 对象存储（可选）----------
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-beijing
COS_BUCKET=nutriai-xxxxxxxx

# ---------- 百度 AI（可选）----------
BAIDU_AI_APP_ID=
BAIDU_AI_API_KEY=
BAIDU_AI_SECRET_KEY=

# ---------- CORS 跨域配置 ----------
# 生产环境填写实际前端域名，多个用逗号分隔
# 示例: https://www.nutriai.com,https://nutriai.com
CORS_ALLOWED_ORIGINS=https://your-domain.com
